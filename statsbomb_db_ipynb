# --- STEP 3B: DISCOVER AND STREAM MATCHES ---
print("Gathering match list...")
all_matches = []
for _, row in df_comp.iterrows():
    comp_id = row['competition_id']
    season_id = row['season_id']
    
    # Matches sit inside a nested "matches" subfolder
    match_url = f"{DATA_BASE_URL}matches/{comp_id}/{season_id}.json"
    response = requests.get(match_url)
    if response.status_code == 200:
        all_matches.extend(response.json())
    # ... [Your existing loop that ends with: all_matches.extend(response.json())] ...

# Convert the array of matches into a Pandas DataFrame
df_matches = pd.json_normalize(all_matches)

# Standardize the column formatting to make it MySQL friendly
df_matches.columns = [col.replace('.', '_') for col in df_matches.columns]

# --- SERIALIZATION FIX ---
# Find columns containing complex types (lists or dictionaries) and convert them to JSON strings
for col in df_matches.columns:
    if df_matches[col].apply(lambda x: isinstance(x, (list, dict))).any():
        df_matches[col] = df_matches[col].apply(lambda x: json.dumps(x) if isinstance(x, (list, dict)) else x)

# Ensure no duplicate entries are sent to the database
df_matches = df_matches.drop_duplicates(subset=['match_id'])

# Write the final structured match list directly to your local MySQL table
df_matches.to_sql('matches', con=engine, if_exists='append', index=False)
print(f"Stored {len(df_matches)} unique matches successfully.")

# --- STEP 3C: STREAM LINEUPS AND EVENTS GAME-BY-GAME ---
print("Streaming Lineups and Events (Game-by-Game)...")
total_games = len(df_matches)

for idx, match_id in enumerate(df_matches['match_id'].unique()):
    m_id = str(match_id)
    
    if idx % 20 == 0 and idx > 0:
        print(f"Progress: {idx}/{total_games} matches securely processed...")

    # Stream Lineups
    lineup_url = f"{GITHUB_BASE}lineups/{m_id}.json"
    l_res = requests.get(lineup_url)
    if l_res.status_code == 200 and l_res.json():
        df_lineups = pd.json_normalize(l_res.json(), record_path=['lineup'], meta=['team_id', 'team_name'])
        df_lineups['match_id'] = int(m_id)
        df_lineups.columns = [col.replace('.', '_') for col in df_lineups.columns]
        df_lineups.to_sql('lineups', con=engine, if_exists='append', index=False)

    # Stream Events
    event_url = f"{GITHUB_BASE}events/{m_id}.json"
