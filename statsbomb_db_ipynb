# --- STEP 2: HYBRID ETL CLEANING FUNCTION ---
def process_events_hybrid(events_json, match_id):
    """
    Extracts high-level relational metrics into dedicated columns
    and serializes the rest into a single JSON blob column.
    """
    cleaned_events = []
    
    for event in events_json:
        # 1. Extract core attributes common to all queries
        flat_event = {
            "event_id": event.get("id"),
            "match_id": int(match_id),
            "index": event.get("index"),
            "period": event.get("period"),
            "timestamp": event.get("timestamp"),
            "minute": event.get("minute"),
            "second": event.get("second"),
            "type_id": event.get("type", {}).get("id"),
            "type_name": event.get("type", {}).get("name"),
            "possession": event.get("possession"),
            "possession_team_id": event.get("possession_team", {}).get("id"),
            "possession_team_name": event.get("possession_team", {}).get("name"),
            "team_id": event.get("team", {}).get("id"),
            "team_name": event.get("team", {}).get("name"),
            "player_id": event.get("player", {}).get("id"),
            "player_name": event.get("player", {}).get("name"),
        }
        
        # 2. Bundle all remaining dynamic properties (pass, shot, etc.) into metadata
        meta_keys = [k for k in event.keys() if k not in ['id', 'index', 'period', 'timestamp', 'minute', 'second', 'type', 'possession', 'possession_team', 'team', 'player']]
        metadata = {k: event[k] for k in meta_keys}
        
        # Convert dictionary to JSON string for MySQL JSON data type compatibility
        flat_event["metadata_blob"] = json.dumps(metadata)
        cleaned_events.append(flat_event)
        
    return pd.DataFrame(cleaned_events)

